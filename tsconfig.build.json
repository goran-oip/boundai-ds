{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "noEmit": false,
    "allowImportingTsExtensions": false,
    "rootDir": "src"
  },
  "include": [
    "src/index.ts",
    "src/components",
    "src/icons/**/*.ts",
    "src/types/**/*.d.ts"
  ],
  "exclude": ["src/stories"]
}
